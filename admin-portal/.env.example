QUADTV_ENV=dev
QUADTV_SECRET_KEY=change-me
QUADTV_ADMIN_USERNAME=admin
QUADTV_ADMIN_PASSWORD=change-me
QUADTV_DATABASE_URL=sqlite:///./data/quadtv_admin.db
QUADTV_CORS_ORIGINS=*
QUADTV_FIREBASE_CREDENTIALS_PATH=

# Provider-panel settings are intentionally placeholders.
# Put real panel URLs and operator credentials in local .env only; do not commit them.
QUADTV_PROVIDER_LIVE_PANEL_URL=
QUADTV_PROVIDER_VOD_PANEL_URL=
QUADTV_PROVIDER_ADMIN_USERNAME=
QUADTV_PROVIDER_ADMIN_PASSWORD=
QUADTV_PROVIDER_AUTH_MODE=manual_import
